import pandas as pd
from services.faker_generator import FakerGenerator

class DataOrchestrator:

    def __init__(self):

        self.fake_generator = FakerGenerator()

    def generate_table_data(self, table_schema, rows=100):

        records = []

        for _ in range(rows):

            row = {}

            for col in table_schema.columns:

                row[col.name] = self.fake_generator.generate(col.name)

            records.append(row)

        return pd.DataFrame(records)