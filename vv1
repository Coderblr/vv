from langchain_openai import ChatOpenAI
from langchain.prompts import PromptTemplate
from prompts.column_prompt import COLUMN_PROMPT
from config import OPENAI_API_KEY

class LLMGenerator:

    def __init__(self):

        self.llm = ChatOpenAI(
            api_key=OPENAI_API_KEY,
            model="gpt-4o-mini",
            temperature=0.3
        )

    def generate_value(self, table_name, column_name, datatype):

        prompt = PromptTemplate.from_template(COLUMN_PROMPT)

        chain = prompt | self.llm

        result = chain.invoke({
            "table_name": table_name,
            "column_name": column_name,
            "datatype": datatype
        })

        return result.content.strip()